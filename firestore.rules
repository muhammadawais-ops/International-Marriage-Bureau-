rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. GLOBAL HELPERS
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // 2. USER PROFILES
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (
        // Enforce secure list queries - no blanket reads
        resource.data.gender != get(/databases/$(database)/documents/users/$(request.auth.uid)).data.gender
      );
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Bio/About
        incoming().diff(existing()).affectedKeys().hasOnly(['bio', 'interests', 'personalityTags', 'updatedAt']) ||
        // Action: Photo Management
        incoming().diff(existing()).affectedKeys().hasOnly(['photos', 'photoPrivacy', 'updatedAt']) ||
        // Action: Status Change (Self-Managed)
        incoming().diff(existing()).affectedKeys().hasOnly(['livingSituation', 'updatedAt'])
      );

      function isValidUser(data) {
        return data.fullName is string && data.fullName.size() <= 100 &&
               data.gender in ['Male', 'Female'] &&
               data.dob is string && // Simplified date check
               data.sect is string &&
               data.isVerified == false && // Users cannot verify themselves
               data.trustScore == 0; // Initial trust score must be zero
      }
    }

    // 3. LIKES & MATCHES
    match /users/{userId}/likes/{likedUserId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(likedUserId) && 
                      likedUserId != userId &&
                      exists(/databases/$(database)/documents/users/$(likedUserId));
    }

    match /matches/{matchId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
    }

    // 4. CHATS
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in existing().participants;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && 
                        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                        incoming().senderId == request.auth.uid &&
                        incoming().timestamp == request.time;
      }
    }
  }
}
